# --- Infrastructure (required) -----------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/d2c
REDIS_URL=redis://localhost:6379/0

# --- Gemini (required for chat + embeddings; chat falls back to a regex
#     refusal and search_examples falls back to substring overlap if blank) -
GEMINI_API_KEY=

# --- Mock SaaS (used by default; ignored when the real-API vars below are set) -
SHOPIFY_BASE_URL=http://localhost:9000/shopify
META_BASE_URL=http://localhost:9000/meta
SHIPROCKET_BASE_URL=http://localhost:9000/shiprocket

# ======================================================================
# REAL-API CREDENTIALS (optional)
# ----------------------------------------------------------------------
# Setting any of the three credential blocks below promotes that connector
# from mock to real mode. Empty values keep the mock_saas behaviour.
# ======================================================================

# --- Shopify Admin REST API --------------------------------------------
# https://shopify.dev/docs/api/admin-rest — create a Custom App in your
# Shopify Partners dev store, install it, copy the Admin API access token.
# Webhook secret comes from the Notifications page once webhooks are wired.
SHOPIFY_SHOP_DOMAIN=                 # e.g. your-store.myshopify.com  (no scheme)
SHOPIFY_ACCESS_TOKEN=                # shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2026-01
SHOPIFY_WEBHOOK_SECRET=              # enables HMAC verification on /webhooks/shopify

# --- Meta Marketing API ------------------------------------------------
# https://developers.facebook.com/docs/marketing-api
# Generate a System User access token with ads_read scope in Business Manager.
# Long-lived tokens are valid 60 days; production needs a rotation worker.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=                  # "act_1234567890" or "1234567890"
META_GRAPH_BASE_URL=https://graph.facebook.com
META_API_VERSION=v19.0

# --- Shiprocket API ----------------------------------------------------
# https://apidocs.shiprocket.in/
# Create a dedicated API USER in the Shiprocket panel (Settings → API →
# Configure). Use that user's email + password here, NOT your dashboard login.
# Token is fetched via POST /v1/external/auth/login and is valid for 240h.
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_API_BASE_URL=https://apiv2.shiprocket.in
